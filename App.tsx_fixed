import React, { useState, useEffect, useMemo } from 'react';
import BudgetForecastingDashboard from './financial-planning/BudgetForecastingDashboard';
import CashFlowStatement from './financial-planning/CashFlowStatement';
import FinancialHealthAssessment from './financial-planning/FinancialHealthAssessment';
import CashFlowManagement from './components/CashFlowManagement';
import DebtManagement from './components/DebtManagement';
import {
    StyleSheet,
    Text,
    View,
    ScrollView,
    TouchableOpacity,
    TextInput,
    SafeAreaView,
    StatusBar,
    Modal,
    Dimensions,
    Share
} from 'react-native';
import Svg, { Rect, Circle, Line, Path, G } from 'react-native-svg';


// Screen Types
type Screen = 'login' | 'register' | 'onboarding' | 'dashboard' | 'reports' | 'transactions' | 'insights' | 'team' | 'budget_forecasting' | 'cash_flow' | 'debt_management_screen' | 'financial_health';
type ReportTab = 'balancesheet' | 'pnl' | 'financial_planning' | 'cash_flow_statement' | 'cash_management' | 'debt_management' | 'financial_health';

// Transaction Type
interface Transaction {
    id: string;
    date: string;
    description: string;
    type: 'income' | 'expense';
    category: string;
    amount: number;
    transactionCategory?: 'purchase' | 'sale' | 'expense' | 'cost' | 'other';
    reference?: string; // Invoice number or reference
    vendorCustomer?: string; // Vendor or customer name
}

export default function App() {
    // Navigation & Authentication states
    const [currentScreen, setCurrentScreen] = useState<Screen>('login');
    const [user, setUser] = useState<{ email: string; businessName: string; role: string } | null>(null);
    const [credentials, setLoginCredentials] = useState({ email: '', password: '', business: '' });

    // App Onboarding Settings
    const [businessType, setBusinessType] = useState('both');
    const [currency, setCurrency] = useState('$');
    const [minReserve, setMinReserve] = useState('5000');
    const [targetMargin, setTargetMargin] = useState('65');

    // Interactive Ledger State (Empty initially for user to populate)
    const [transactions, setTransactions] = useState<Transaction[]>([
        {
            id: '1',
            date: '2026-05-10',
            description: 'Enterprise Software SLA License',
            type: 'income',
            category: 'Software sales',
            amount: 85000,
            transactionCategory: 'sale',
            vendorCustomer: 'TechCorp Inc.',
            reference: 'INV-001'
        },
        // Add similar updates to other transactions
    ]);

    // Transaction logging modal & form controllers
    const [isTxModalOpen, setIsTxModalOpen] = useState(false);
    const [newTx, setNewTx] = useState({
        description: '',
        amount: '',
        type: 'expense' as 'income' | 'expense',
        category: 'Personnel expenses',
        transactionCategory: 'expense' as 'purchase' | 'sale' | 'expense' | 'cost' | 'other',
        reference: '',
        vendorCustomer: ''
    });
    // Report tab manager
    const [activeReportTab, setActiveReportTab] = useState<ReportTab>('balancesheet');

    // "One Thing" recommendation trigger rules
    const oneThingInsight = useMemo(() => {
        const totalIncome = transactions.filter(t => t.type === 'income').reduce((sum, t) => sum + t.amount, 0);
        const totalExpense = transactions.filter(t => t.type === 'expense').reduce((sum, t) => sum + t.amount, 0);
        const netProfit = totalIncome - totalExpense;
        const margin = totalIncome > 0 ? (netProfit / totalIncome) * 100 : 0;

        if (parseFloat(minReserve) > (totalIncome - totalExpense)) {
            return {
                severity: 'critical',
                title: 'Capital Reserve Threshold Breached',
                action: `Your net liquid reserves are below your configured minimum buffer of ${currency}${minReserve}. Immediate cost-reallocation advised.`,
                tag: 'LIQUIDITY WARNING'
            };
        } else if (margin < parseFloat(targetMargin)) {
            return {
                severity: 'warning',
                title: 'Margins Are Dropping Below Target',
                action: `Current profit margin is ${margin.toFixed(1)}% vs your goal of ${targetMargin}%. Review top cost categories now.`,
                tag: 'MARGIN WARNING'
            };
        }
        return {
            severity: 'healthy',
            title: 'Everything Looks Healthy Today',
            action: 'Your core metrics are stable. Optional: review your top 3 highest-cost categories for optimization opportunities.',
            tag: 'HEALTHY'
        };
    }, [transactions, minReserve, targetMargin, currency]);

    // Combined Financial Aggregations based on Live Ledger State
    const finance = useMemo(() => {
        const income = transactions.filter(t => t.type === 'income').reduce((sum, t) => sum + t.amount, 0);
        const expense = transactions.filter(t => t.type === 'expense').reduce((sum, t) => sum + t.amount, 0);
        const profit = income - expense;
        const margin = income > 0 ? (profit / income) * 100 : 0;
        const assets = income; // Dynamic assets tracking based on income
        const liabilities = expense; // Dynamic liabilities tracking based on expenses
        const equity = assets - liabilities;

        return {
            income,
            expense,
            profit,
            margin,
            assets,
            liabilities,
            equity
        };
    }, [transactions]);

    // Log in workflow
    const handleLogin = () => {
        if (credentials.email && credentials.password) {
            setUser({ email: credentials.email, businessName: credentials.business, role: 'Administrator' });
            setCurrentScreen('onboarding');
        }
    };

    // Log new transaction to local memory ledger
    const handleAddTransaction = () => {
        if (newTx.description && newTx.amount) {
            const amt = parseFloat(newTx.amount);
            if (!isNaN(amt)) {
                const item: Transaction = {
                    id: Math.random().toString(),
                    date: new Date().toISOString().split('T')[0],
                    description: newTx.description,
                    type: newTx.type,
                    category: newTx.category,
                    amount: amt,
                    transactionCategory: newTx.transactionCategory,
                    reference: newTx.reference,
                    vendorCustomer: newTx.vendorCustomer
                };
                setTransactions([item, ...transactions]);
                setNewTx({
                    description: '',
                    amount: '',
                    type: 'expense',
                    category: 'Personnel expenses',
                    transactionCategory: 'expense',
                    reference: '',
                    vendorCustomer: ''
                });
                setIsTxModalOpen(false);
            }
        }
    };

    const handleShareReport = async (title: string, content: string) => {
        try {
            await Share.share({
                message: `${title}\n\n${content}`,
            });
        } catch (e) {
            console.log('Share error', e);
        }
    };

    // Render Navbar / Header
    const renderHeader = () => (
        <View style={styles.header}>
            <View>
                <Text style={styles.headerTitle}>FinanceBook</Text>
                <Text style={styles.headerSubtitle}>{user?.businessName || 'Business Suite'}</Text>
            </View>
            <View style={styles.headerRight}>
                <Text style={styles.headerUser}>{user?.email.split('@')[0] || 'Admin'}</Text>
                <TouchableOpacity style={styles.signOutBtn} onPress={() => { setUser(null); setCurrentScreen('login'); }}>
                    <Text style={styles.signOutText}>Sign Out</Text>
                </TouchableOpacity>
            </View>
        </View>
    );

    // Render Sidebar / Bottom Navigation tab actions
    const renderFooterNav = () => (
        <View style={styles.footerNav}>
            <TouchableOpacity
                style={[styles.navItem, currentScreen === 'dashboard' && styles.navItemActive]}
                onPress={() => setCurrentScreen('dashboard')}
            >
                <Text style={[styles.navText, currentScreen === 'dashboard' && styles.navTextActive]}>Dashboard</Text>
            </TouchableOpacity>
            <TouchableOpacity
                style={[styles.navItem, currentScreen === 'reports' && styles.navItemActive]}
                onPress={() => setCurrentScreen('reports')}
            >
                <Text style={[styles.navText, currentScreen === 'reports' && styles.navTextActive]}>Reports</Text>
            </TouchableOpacity>
            <TouchableOpacity
                style={[styles.navItem, currentScreen === 'transactions' && styles.navItemActive]}
                onPress={() => setCurrentScreen('transactions')}
            >
                <Text style={[styles.navText, currentScreen === 'transactions' && styles.navTextActive]}>Ledger</Text>
            </TouchableOpacity>
            <TouchableOpacity
                style={[styles.navItem, currentScreen === 'insights' && styles.navItemActive]}
                onPress={() => setCurrentScreen('insights')}
            >
                <Text style={[styles.navText, currentScreen === 'insights' && styles.navTextActive]}>Insights</Text>
            </TouchableOpacity>
        </View>
    );

    // Enhanced navigation between related screens
    const navigateToScreen = (screen: Screen) => {
        setCurrentScreen(screen);
    };

    return (
        <SafeAreaView style={styles.safeContainer}>
            <StatusBar barStyle="light-content" backgroundColor="#0f172a" />

            {/* ----------------- SCREEN: LOGIN ----------------- */}
            {currentScreen === 'login' && (
                <ScrollView contentContainerStyle={styles.centerScroll}>
                    <View style={styles.cardContainer}>
                        <Text style={styles.mainTitle}>FinanceBook Mobile</Text>
                        <Text style={styles.subTitle}>SME Corporate Ledger Packaging</Text>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Business Entity Name</Text>
                            <TextInput
                                style={styles.input}
                                value={credentials.business}
                                onChangeText={(text) => setLoginCredentials({ ...credentials, business: text })}
                                placeholder="Acme Corp"
                                placeholderTextColor="#64748b"
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Corporate Email Administrator</Text>
                            <TextInput
                                style={styles.input}
                                keyboardType="email-address"
                                autoCapitalize="none"
                                value={credentials.email}
                                onChangeText={(text) => setLoginCredentials({ ...credentials, email: text })}
                                placeholder="admin@acme.com"
                                placeholderTextColor="#64748b"
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Security Password</Text>
                            <TextInput
                                style={styles.input}
                                secureTextEntry
                                value={credentials.password}
                                onChangeText={(text) => setLoginCredentials({ ...credentials, password: text })}
                                placeholder="••••••••"
                                placeholderTextColor="#64748b"
                            />
                        </View>

                        <TouchableOpacity style={styles.primaryBtn} onPress={handleLogin}>
                            <Text style={styles.btnText}>Authenticate & Proceed</Text>
                        </TouchableOpacity>

                        <TouchableOpacity style={styles.textLink} onPress={() => setCurrentScreen('register')}>
                            <Text style={styles.linkText}>Create a new Account</Text>
                        </TouchableOpacity>
                    </View>
                </ScrollView>
            )}

            {/* ----------------- SCREEN: REGISTER ----------------- */}
            {currentScreen === 'register' && (
                <ScrollView contentContainerStyle={styles.centerScroll}>
                    <View style={styles.cardContainer}>
                        <Text style={styles.mainTitle}>Create Entity Account</Text>
                        <Text style={styles.subTitle}>Establish double-entry ledger vault</Text>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Company/Business Name</Text>
                            <TextInput style={styles.input} placeholder="Company Ltd" placeholderTextColor="#64748b" />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Full Administrator Name</Text>
                            <TextInput style={styles.input} placeholder="Name" placeholderTextColor="#64748b" />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Business Email</Text>
                            <TextInput style={styles.input} keyboardType="email-address" placeholder="email@company.com" placeholderTextColor="#64748b" />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Passcode Vault Secret</Text>
                            <TextInput style={styles.input} secureTextEntry placeholder="••••••••" placeholderTextColor="#64748b" />
                        </View>

                        <TouchableOpacity style={styles.primaryBtn} onPress={() => setCurrentScreen('login')}>
                            <Text style={styles.btnText}>Register New Account</Text>
                        </TouchableOpacity>

                        <TouchableOpacity style={styles.textLink} onPress={() => setCurrentScreen('login')}>
                            <Text style={styles.linkText}>Already registered? Login</Text>
                        </TouchableOpacity>
                    </View>
                </ScrollView>
            )}

            {/* ----------------- SCREEN: ONBOARDING ----------------- */}
            {currentScreen === 'onboarding' && (
                <ScrollView contentContainerStyle={styles.centerScroll}>
                    <View style={styles.cardContainer}>
                        <Text style={styles.mainTitle}>Guided Setup</Text>
                        <Text style={styles.subTitle}>Configure local benchmarking formulas</Text>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Industry Operating Sector</Text>
                            <View style={styles.toggleRow}>
                                <TouchableOpacity
                                    style={[styles.toggleBtn, businessType === 'product' && styles.toggleBtnActive]}
                                    onPress={() => setBusinessType('product')}
                                >
                                    <Text style={[styles.toggleText, businessType === 'product' && styles.toggleTextActive]}>Product</Text>
                                </TouchableOpacity>
                                <TouchableOpacity
                                    style={[styles.toggleBtn, businessType === 'service' && styles.toggleBtnActive]}
                                    onPress={() => setBusinessType('service')}
                                >
                                    <Text style={[styles.toggleText, businessType === 'service' && styles.toggleTextActive]}>Service</Text>
                                </TouchableOpacity>
                                <TouchableOpacity
                                    style={[styles.toggleBtn, businessType === 'both' && styles.toggleBtnActive]}
                                    onPress={() => setBusinessType('both')}
                                >
                                    <Text style={[styles.toggleText, businessType === 'both' && styles.toggleTextActive]}>Hybrid</Text>
                                </TouchableOpacity>
                            </View>
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Reporting Currency Symbol</Text>
                            <TextInput
                                style={styles.input}
                                value={currency}
                                onChangeText={setCurrency}
                                placeholder="$"
                                placeholderTextColor="#64748b"
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Target Gross Margin Percent (%)</Text>
                            <TextInput
                                style={styles.input}
                                value={targetMargin}
                                onChangeText={setTargetMargin}
                                keyboardType="numeric"
                                placeholder="65"
                                placeholderTextColor="#64748b"
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.label}>Minimum Liquid Cash Reserve Limit</Text>
                            <TextInput
                                style={styles.input}
                                value={minReserve}
                                onChangeText={setMinReserve}
                                keyboardType="numeric"
                                placeholder="5000"
                                placeholderTextColor="#64748b"
                            />
                        </View>

                        <TouchableOpacity style={styles.primaryBtn} onPress={() => setCurrentScreen('dashboard')}>
                            <Text style={styles.btnText}>Complete Onboarding</Text>
                        </TouchableOpacity>
                    </View>
                </ScrollView>
            )}

            {/* ----------------- SCREEN: DASHBOARD ----------------- */}
            {currentScreen === 'dashboard' && (
                <View style={styles.mainWrapper}>
                    {renderHeader()}
                    <ScrollView style={styles.contentScroll}>

                        {/* Daily "One Thing" Action Feed */}
                        <View style={[
                            styles.oneThingCard,
                            oneThingInsight.severity === 'critical' ? styles.borderRed :
                                oneThingInsight.severity === 'warning' ? styles.borderYellow : styles.borderGreen
                        ]}>
                            <View style={styles.rowBetween}>
                                <Text style={styles.oneThingTitle}>One Thing For Today</Text>
                                <View style={[
                                    styles.badge,
                                    oneThingInsight.severity === 'critical' ? styles.bgRed :
                                        oneThingInsight.severity === 'warning' ? styles.bgYellow : styles.bgGreen
                                ]}>
                                    <Text style={styles.badgeText}>{oneThingInsight.tag}</Text>
                                </View>
                            </View>
                            <Text style={styles.oneThingAction}>{oneThingInsight.title}</Text>
                            <Text style={styles.oneThingHelp}>{oneThingInsight.action}</Text>
                        </View>

                        {/* Metric 1 & 2: Scoreboard 5-Number Feed */}
                        <Text style={styles.sectionHeader}>Business Scoreboard - Actuals</Text>

                        <View style={styles.scoreboardGrid}>
                            <View style={[styles.scoreItem, styles.borderGreen]}>
                                <Text style={styles.scoreLabel}>Gross Revenue</Text>
                                <Text style={styles.scoreVal}>{currency}{finance.income.toLocaleString()}</Text>
                                <Text style={styles.scoreChange}>↑ Stable Base Actuals</Text>
                            </View>

                            <View style={[styles.scoreItem, finance.margin >= parseFloat(targetMargin) ? styles.borderGreen : styles.borderYellow]}>
                                <Text style={styles.scoreLabel}>Gross Margin</Text>
                                <Text style={styles.scoreVal}>{finance.margin.toFixed(1)}%</Text>
                                <Text style={styles.scoreChange}>Goal: {targetMargin}%</Text>
                            </View>

                            <View style={[styles.scoreItem, finance.profit > 0 ? styles.borderGreen : styles.borderRed]}>
                                <Text style={styles.scoreLabel}>Net Profit</Text>
                                <Text style={styles.scoreVal}>{currency}{finance.profit.toLocaleString()}</Text>
                                <Text style={styles.scoreChange}>{finance.profit > 0 ? '🟢 Profit-Positive' : '🔴 Capital Loss'}</Text>
                            </View>

                            <View style={[styles.scoreItem, (finance.assets - finance.liabilities) >= parseFloat(minReserve) ? styles.borderGreen : styles.borderRed]}>
                                <Text style={styles.scoreLabel}>Cash Balance</Text>
                                <Text style={styles.scoreVal}>{currency}{(finance.income - finance.expense).toLocaleString()}</Text>
                                <Text style={styles.scoreChange}>Buffer target: {currency}{minReserve}</Text>
                            </View>

                            <View style={[styles.scoreItem, styles.borderGreen]}>
                                <Text style={styles.scoreLabel}>OpEx Burn Rate</Text>
                                <Text style={styles.scoreVal}>{currency}{finance.expense.toLocaleString()}/mo</Text>
                                <Text style={styles.scoreChange}>Personnel weighted</Text>
                            </View>
                        </View>

                        {/* Quick Actions */}
                        <View style={styles.actionsBlock}>
                            <TouchableOpacity style={styles.actionBtn} onPress={() => setIsTxModalOpen(true)}>
                                <Text style={styles.actionBtnText}>+ Log Receipt or Expense</Text>
                            </TouchableOpacity>
                            <TouchableOpacity style={[styles.actionBtn, styles.bgSlate]} onPress={() => setCurrentScreen('reports')}>
                                <Text style={styles.actionBtnText}>Open Reporting Audit Logs</Text>
                            </TouchableOpacity>
                        </View>

                        {/* Advanced Tools */}
                        <Text style={styles.sectionHeader}>Advanced Tools</Text>
                        <View style={styles.actionsBlock}>
                            <TouchableOpacity
                                style={[styles.actionBtn, styles.bgSlate]}
                                onPress={() => {
                                    setActiveReportTab('financial_planning');
                                    setCurrentScreen('reports');
                                }}
                            >
                                <Text style={styles.actionBtnText}>Budget Forecasting</Text>
                            </TouchableOpacity>
                            <TouchableOpacity
                                style={[styles.actionBtn, styles.bgSlate]}
                                onPress={() => {
                                    setActiveReportTab('cash_flow_statement');
                                    setCurrentScreen('reports');
                                }}
                            >
                                <Text style={styles.actionBtnText}>Cash Flow Analysis</Text>
                            </TouchableOpacity>
                        </View>

                    </ScrollView>
                    {renderFooterNav()}
                </View>
            )}



            {/* ----------------- SCREEN: REPORTS ----------------- */}
            {currentScreen === 'reports' && (
                <View style={styles.mainWrapper}>
                    {renderHeader()}

                    <View style={styles.reportsTabsRow}>
                        <ScrollView horizontal showsHorizontalScrollIndicator={false}>
                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'balancesheet' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('balancesheet')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'balancesheet' && styles.repTabActiveText]}>BS Comparer</Text>
                            </TouchableOpacity>

                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'pnl' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('pnl')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'pnl' && styles.repTabActiveText]}>P&L Statement</Text>
                            </TouchableOpacity>

                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'financial_planning' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('financial_planning')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'financial_planning' && styles.repTabActiveText]}>Financial Planning</Text>
                            </TouchableOpacity>

                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'cash_flow_statement' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('cash_flow_statement')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'cash_flow_statement' && styles.repTabActiveText]}>Cash Flow Statement</Text>
                            </TouchableOpacity>
                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'cash_management' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('cash_management')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'cash_management' && styles.repTabActiveText]}>Cash Flow Management</Text>
                            </TouchableOpacity>
                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'debt_management' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('debt_management')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'debt_management' && styles.repTabActiveText]}>Debt Management</Text>
                            </TouchableOpacity>
                            <TouchableOpacity
                                style={[styles.repTab, activeReportTab === 'financial_health' && styles.repTabActive]}
                                onPress={() => setActiveReportTab('financial_health')}
                            >
                                <Text style={[styles.repTabText, activeReportTab === 'financial_health' && styles.repTabActiveText]}>Financial Health</Text>
                            </TouchableOpacity>
                        </ScrollView>
                    </View>

                    <ScrollView style={styles.contentScroll}>

                        {/* TAB 1: COMPARATIVE BALANCE SHEET */}
                        {activeReportTab === 'balancesheet' && (
                            <View style={styles.reportCard}>
                                <View style={styles.rowBetween}>
                                    <Text style={styles.reportTitle}>📊 BALANCE SHEET</Text>
                                    <TouchableOpacity style={styles.exportMinBtn} onPress={() => handleShareReport("Balance Sheet", `Total Assets: ${currency}${finance.assets.toLocaleString()} | Total Liabilities: ${currency}${finance.liabilities.toLocaleString()} | Owner's Equity: ${currency}${finance.equity.toLocaleString()}`)}>
                                        <Text style={styles.exportMinText}>Share</Text>
                                    </TouchableOpacity>
                                </View>
                                <Text style={styles.reportCap}>Snapshot of what your business owns (assets) and owes (liabilities) at this point in time</Text>

                                {/* Table Header */}
                                <View style={[styles.tableRow, styles.bgSlateDark]}>
                                    <Text style={[styles.thCell, { flex: 1.5 }]}>Description</Text>
                                    <Text style={styles.thCell}>Amount</Text>
                                    <Text style={styles.thCell}>%</Text>
                                    <Text style={styles.thCell}>Notes</Text>
                                </View>

                                {/* ASSETS HEADER */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', fontSize: 16 }]}>ASSETS</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* CURRENT ASSETS HEADER */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>Current Assets</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Cash */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Cash</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.2).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Accounts Receivable */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Accounts Receivable</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.15).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Inventory */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Inventory</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.5).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Total Current Assets */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 30 }]}>Total Current Assets</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.85).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>{finance.income > 0 ? '85%' : '0%'}</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* NON-CURRENT ASSETS HEADER */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>Non-Current Assets</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Plant and Equipment */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Plant and Equipment</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.05).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Business Premises */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Business Premises</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.65).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Vehicles */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Vehicles</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.07).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Total Non-Current Assets */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 30 }]}>Total Non-Current Assets</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{(finance.income * 0.77).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>{finance.income > 0 ? '77%' : '0%'}</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* TOTAL ASSETS */}
                                <View style={[styles.tableRow, styles.bgSlate]}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', color: '#fff' }]}>TOTAL ASSETS</Text>
                                    <Text style={[styles.tdCell, { color: '#fff' }]}>{currency}{finance.assets.toLocaleString()}</Text>
                                    <Text style={[styles.tdCell, { color: '#fff' }]}>{finance.income > 0 ? '100%' : '0%'}</Text>
                                    <Text style={[styles.tdCell, { color: '#fff' }]}></Text>
                                </View>

                                {/* LIABILITIES HEADER */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', fontSize: 16, paddingTop: 10 }]}>LIABILITIES</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* CURRENT LIABILITIES HEADER */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>Current Liabilities</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Accounts Payable */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Accounts Payable</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.25).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Bank Overdraft */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Bank Overdraft</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.1).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Credit Card Debt */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Credit Card Debt</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.05).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Tax Liability */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Tax Liability</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.3).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Total Current Liabilities */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 30 }]}>Total Current Liabilities</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.7).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>{finance.income > 0 ? (finance.expense * 0.7 / finance.income * 100).toFixed(1) : '0'}%</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* NON-CURRENT LIABILITIES HEADER */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>Non-Current Liabilities</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Long term business loan 1 */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Long term business loan 1</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.45).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Long term business loan 2 */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 30 }]}>Long term business loan 2</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.05).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Total Non-Current Liabilities */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 30 }]}>Total Non-Current Liabilities</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{(finance.expense * 0.5).toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>{finance.income > 0 ? (finance.expense * 0.5 / finance.income * 100).toFixed(1) : '0'}%</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* TOTAL LIABILITIES */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>TOTAL LIABILITIES</Text>
                                    <Text style={[styles.tdCell, styles.textRed]}>{currency}{finance.liabilities.toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>{finance.income > 0 ? (finance.liabilities / finance.income * 100).toFixed(1) : '0'}%</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* NET ASSETS */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>NET ASSETS</Text>
                                    <Text style={[styles.tdCell, finance.profit >= 0 ? styles.textGreen : styles.textRed]}>{currency}{finance.profit.toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>{finance.income > 0 ? (finance.profit / finance.income * 100).toFixed(1) : '0'}%</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* OWNERS EQUITY */}
                                <View style={[styles.tableRow, styles.bgSlate]}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', color: '#fff' }]}>OWNERS EQUITY</Text>
                                    <Text style={[styles.tdCell, { color: '#fff' }]}>{currency}{finance.equity.toLocaleString()}</Text>
                                    <Text style={[styles.tdCell, { color: '#fff' }]}>{finance.income > 0 ? (finance.equity / finance.income * 100).toFixed(1) : '0'}%</Text>
                                    <Text style={[styles.tdCell, { color: '#fff' }]}></Text>
                                </View>
                            </View>
                        )}

                        {/* TAB 5: PROFIT & LOSS STATEMENT */}
                        {activeReportTab === 'pnl' && (
                            <View style={styles.reportCard}>
                                <View style={styles.rowBetween}>
                                    <Text style={styles.reportTitle}>📊 PROFIT & LOSS STATEMENT</Text>
                                    <TouchableOpacity style={styles.exportMinBtn} onPress={() => handleShareReport("Profit & Loss Statement", `Total Income: ${currency}${finance.income.toLocaleString()}, Total Expenses: ${currency}${finance.expense.toLocaleString()}, Net Profit: ${currency}${finance.profit.toLocaleString()}`)}>
                                        <Text style={styles.exportMinText}>Share</Text>
                                    </TouchableOpacity>
                                </View>
                                <Text style={styles.reportCap}>Revenue, expenses, and profit overview for the period</Text>

                                {/* P&L Table Header */}
                                <View style={[styles.tableRow, styles.bgSlateDark]}>
                                    <Text style={[styles.thCell, { flex: 1.5 }]}>Description</Text>
                                    <Text style={styles.thCell}>Amount</Text>
                                    <Text style={styles.thCell}>%</Text>
                                    <Text style={styles.thCell}>Notes</Text>
                                </View>

                                {/* Total Revenue */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold' }]}>Total Revenue</Text>
                                    <Text style={[styles.tdCell, styles.textGreen]}>{currency}{finance.income.toLocaleString()}</Text>
                                    <Text style={styles.tdCell}>100%</Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Less header */}
                                <View style={styles.tableRow}>
                                    <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', fontStyle: 'italic' }]}>Less</Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                    <Text style={styles.tdCell}></Text>
                                </View>

                                {/* Determine COGS based on transaction categories */}
                                {(() => {
                                    // Identify COGS-related categories (these could be configurable in a real app)
                                    const cogsCategories = ['materials', 'raw materials', 'production labor', 'subcontracted labor', 'direct labor', 'cost of goods', 'supplies', 'inventory', 'cost of sales'];

                                    // Calculate COGS from transactions that match COGS categories
                                    const cogsAmount = transactions
                                        .filter(t => t.type === 'expense' && cogsCategories.some(cogCat =>
                                            t.category.toLowerCase().includes(cogCat) || cogCat.includes(t.category.toLowerCase())
                                        ))
                                        .reduce((sum, t) => sum + t.amount, 0);

                                    // Calculate operating expenses (everything else)
                                    const operatingExpenses = finance.expense - cogsAmount;
                                    const grossProfit = finance.income - cogsAmount;
                                    const cogsPercentage = finance.income > 0 ? (cogsAmount / finance.income * 100).toFixed(1) : '0';
                                    const grossProfitPercentage = finance.income > 0 ? (grossProfit / finance.income * 100).toFixed(1) : '0';

                                    return (
                                        <>
                                            {/* Cost of Goods Sold */}
                                            <View style={styles.tableRow}>
                                                <Text style={[styles.tdCell, { flex: 1.5 }]}>Cost of Goods Sold</Text>
                                                <Text style={[styles.tdCell, styles.textRed]}>-{currency}{cogsAmount.toLocaleString()}</Text>
                                                <Text style={styles.tdCell}>{cogsPercentage}%</Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>

                                            {/* Gross Profit */}
                                            <View style={styles.tableRow}>
                                                <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold' }]}>Gross Profit</Text>
                                                <Text style={[styles.tdCell, styles.textGreen]}>{currency}{grossProfit.toLocaleString()}</Text>
                                                <Text style={styles.tdCell}>{grossProfitPercentage}%</Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>

                                            {/* Less header for expenses */}
                                            <View style={styles.tableRow}>
                                                <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', fontStyle: 'italic' }]}>Less</Text>
                                                <Text style={styles.tdCell}></Text>
                                                <Text style={styles.tdCell}></Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>

                                            {/* Operating Expenses header */}
                                            <View style={styles.tableRow}>
                                                <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold' }]}>Operating Expenses</Text>
                                                <Text style={styles.tdCell}></Text>
                                                <Text style={styles.tdCell}></Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>

                                            {/* Operating Expense Breakdown */}
                                            {Array.from(
                                                new Set(transactions.filter(t =>
                                                    t.type === 'expense' &&
                                                    !cogsCategories.some(cogCat =>
                                                        t.category.toLowerCase().includes(cogCat) || cogCat.includes(t.category.toLowerCase())
                                                    )
                                                ).map(t => t.category))
                                            ).map((category, index) => {
                                                const categoryAmount = transactions
                                                    .filter(t =>
                                                        t.type === 'expense' &&
                                                        t.category === category &&
                                                        !cogsCategories.some(cogCat =>
                                                            t.category.toLowerCase().includes(cogCat) || cogCat.includes(t.category.toLowerCase())
                                                        )
                                                    )
                                                    .reduce((sum, t) => sum + t.amount, 0);

                                                return (
                                                    <View key={`operating-${index}`} style={styles.tableRow}>
                                                        <Text style={[styles.tdCell, { flex: 1.5, paddingLeft: 15 }]}>{category}</Text>
                                                        <Text style={[styles.tdCell, styles.textRed]}>{currency}{categoryAmount.toLocaleString()}</Text>
                                                        <Text style={styles.tdCell}></Text>
                                                        <Text style={styles.tdCell}></Text>
                                                    </View>
                                                );
                                            })}

                                            {/* Total Operating Expenses */}
                                            <View style={styles.tableRow}>
                                                <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', paddingLeft: 15 }]}>Total Operating Expenses</Text>
                                                <Text style={[styles.tdCell, styles.textRed]}>-{currency}{operatingExpenses.toLocaleString()}</Text>
                                                <Text style={styles.tdCell}>{finance.income > 0 ? (operatingExpenses / finance.income * 100).toFixed(1) : '0'}%</Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>

                                            {/* Equals header */}
                                            <View style={styles.tableRow}>
                                                <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', fontStyle: 'italic' }]}>Equals</Text>
                                                <Text style={styles.tdCell}></Text>
                                                <Text style={styles.tdCell}></Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>

                                            {/* Net Profit */}
                                            <View style={[styles.tableRow, styles.bgSlate]}>
                                                <Text style={[styles.tdCell, { flex: 1.5, fontWeight: 'bold', color: '#fff' }]}>Net Profit</Text>
                                                <Text style={[styles.tdCell, { color: '#fff' }]}>{currency}{finance.profit.toLocaleString()}</Text>
                                                <Text style={[styles.tdCell, { color: '#fff' }]}>{finance.income > 0 ? (finance.profit / finance.income * 100).toFixed(1) : '0'}%</Text>
                                                <Text style={styles.tdCell}></Text>
                                            </View>
                                        </>
                                    );
                                })()}
                            </View>
                        )}

                        {/* TAB 7: FINANCIAL PLANNING & MANAGEMENT */}
                        {activeReportTab === 'financial_planning' && (
                            <BudgetForecastingDashboard
                                finance={finance}
                                currency={currency}
                                minReserve={minReserve}
                                targetMargin={targetMargin}
                            />
                        )}

                        {/* TAB 9: CASH FLOW STATEMENT */}
                        {activeReportTab === 'cash_flow_statement' && (
                            <CashFlowStatement
                                finance={finance}
                                currency={currency}
                                minReserve={minReserve}
                                targetMargin={targetMargin}
                            />
                        )}

                        {/* TAB 10: CASH FLOW MANAGEMENT */}
                        {activeReportTab === 'cash_management' && (
                            <CashFlowManagement
                                finance={finance}
                                currency={currency}
                                minReserve={minReserve}
                                targetMargin={targetMargin}
                            />
                        )}

                        {/* TAB 11: DEBT MANAGEMENT */}
                        {activeReportTab === 'debt_management' && (
                            <DebtManagement
                                finance={{
                                    assets: finance.assets,
                                    liabilities: finance.liabilities,
                                    equity: finance.equity
                                }}
                                currency={currency}
                            />
                        )}

                        {/* TAB 12: FINANCIAL HEALTH ASSESSMENT */}
                        {activeReportTab === 'financial_health' && (
                            <FinancialHealthAssessment
                                finance={finance}
                                currency={currency}
                                minReserve={minReserve}
                                targetMargin={targetMargin}
                            />
                        )}

                    </ScrollView>
                    {renderFooterNav()}
                </View>
            )}

            {/* ----------------- SCREEN: TRANSACTIONS ----------------- */}
            {/* ----------------- SCREEN: TRANSACTIONS ----------------- */}
            {currentScreen === 'transactions' && (
                <View style={styles.mainWrapper}>
                    {renderHeader()}
                    <View style={styles.rowBetweenCompact}>
                        <Text style={styles.sectionHeader}>Enhanced Ledger</Text>
                        <TouchableOpacity style={styles.logBtnCompact} onPress={() => setIsTxModalOpen(true)}>
                            <Text style={styles.logBtnCompactText}>+ Log Entry</Text>
                        </TouchableOpacity>
                    </View>

                    <ScrollView style={styles.contentScroll}>
                        {/* Summary Cards */}
                        <View style={styles.summaryContainer}>
                            <View style={styles.summaryCard}>
                                <Text style={styles.summaryLabel}>Purchases</Text>
                                <Text style={styles.summaryValue}>{currency}{
                                    transactions
                                        .filter(t => t.transactionCategory === 'purchase')
                                        .reduce((sum, t) => sum + t.amount, 0)
                                        .toLocaleString()
                                }</Text>
                                <Text style={styles.summaryCount}>
                                    {transactions.filter(t => t.transactionCategory === 'purchase').length} entries
                                </Text>
                            </View>
                            <View style={styles.summaryCard}>
                                <Text style={styles.summaryLabel}>Sales</Text>
                                <Text style={styles.summaryValue}>{currency}{
                                    transactions
                                        .filter(t => t.transactionCategory === 'sale')
                                        .reduce((sum, t) => sum + t.amount, 0)
                                        .toLocaleString()
                                }</Text>
                                <Text style={styles.summaryCount}>
                                    {transactions.filter(t => t.transactionCategory === 'sale').length} entries
                                </Text>
                            </View>
                            <View style={styles.summaryCard}>
                                <Text style={styles.summaryLabel}>Expenses</Text>
                                <Text style={styles.summaryValue}>{currency}{
                                    transactions
                                        .filter(t => t.transactionCategory === 'expense')
                                        .reduce((sum, t) => sum + t.amount, 0)
                                        .toLocaleString()
                                }</Text>
                                <Text style={styles.summaryCount}>
                                    {transactions.filter(t => t.transactionCategory === 'expense').length} entries
                                </Text>
                            </View>
                        </View>

                        {/* Purchase Transactions Table */}
                        <View style={styles.tableSection}>
                            <Text style={styles.tableTitle}>Purchase Transactions</Text>
                            <View style={styles.tableHeader}>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Date</Text>
                                <Text style={[styles.columnHeader, { flex: 2.5 }]}>Description</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Vendor</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5, textAlign: 'right' }]}>Amount</Text>
                            </View>
                            {transactions
                                .filter(t => t.transactionCategory === 'purchase')
                                .map((tx) => (
                                    <View key={tx.id} style={styles.tableRow}>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.date}</Text>
                                        <Text style={[styles.cell, { flex: 2.5 }]} numberOfLines={1}>{tx.description}</Text>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.vendorCustomer || '-'}</Text>
                                        <Text style={[styles.cell, { flex: 1.5, textAlign: 'right' }]}>
                                            {currency}{tx.amount.toLocaleString()}
                                        </Text>
                                    </View>
                                ))
                            }
                        </View>

                        {/* Sales Transactions Table */}
                        <View style={styles.tableSection}>
                            <Text style={styles.tableTitle}>Sales Transactions</Text>
                            <View style={styles.tableHeader}>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Date</Text>
                                <Text style={[styles.columnHeader, { flex: 2.5 }]}>Description</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Customer</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5, textAlign: 'right' }]}>Amount</Text>
                            </View>
                            {transactions
                                .filter(t => t.transactionCategory === 'sale')
                                .map((tx) => (
                                    <View key={tx.id} style={styles.tableRow}>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.date}</Text>
                                        <Text style={[styles.cell, { flex: 2.5 }]} numberOfLines={1}>{tx.description}</Text>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.vendorCustomer || '-'}</Text>
                                        <Text style={[styles.cell, { flex: 1.5, textAlign: 'right' }]}>
                                            {currency}{tx.amount.toLocaleString()}
                                        </Text>
                                    </View>
                                ))
                            }
                        </View>

                        {/* Expense Transactions Table */}
                        <View style={styles.tableSection}>
                            <Text style={styles.tableTitle}>Expense Transactions</Text>
                            <View style={styles.tableHeader}>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Date</Text>
                                <Text style={[styles.columnHeader, { flex: 2.5 }]}>Description</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Category</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5, textAlign: 'right' }]}>Amount</Text>
                            </View>
                            {transactions
                                .filter(t => t.transactionCategory === 'expense')
                                .map((tx) => (
                                    <View key={tx.id} style={styles.tableRow}>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.date}</Text>
                                        <Text style={[styles.cell, { flex: 2.5 }]} numberOfLines={1}>{tx.description}</Text>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.category}</Text>
                                        <Text style={[styles.cell, { flex: 1.5, textAlign: 'right' }]}>
                                            {currency}{tx.amount.toLocaleString()}
                                        </Text>
                                    </View>
                                ))
                            }
                        </View>

                        {/* Cost Transactions Table */}
                        <View style={styles.tableSection}>
                            <Text style={styles.tableTitle}>Cost Transactions</Text>
                            <View style={styles.tableHeader}>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Date</Text>
                                <Text style={[styles.columnHeader, { flex: 2.5 }]}>Description</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5 }]}>Reference</Text>
                                <Text style={[styles.columnHeader, { flex: 1.5, textAlign: 'right' }]}>Amount</Text>
                            </View>
                            {transactions
                                .filter(t => t.transactionCategory === 'cost')
                                .map((tx) => (
                                    <View key={tx.id} style={styles.tableRow}>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.date}</Text>
                                        <Text style={[styles.cell, { flex: 2.5 }]} numberOfLines={1}>{tx.description}</Text>
                                        <Text style={[styles.cell, { flex: 1.5 }]}>{tx.reference || '-'}</Text>
                                        <Text style={[styles.cell, { flex: 1.5, textAlign: 'right' }]}>
                                            {currency}{tx.amount.toLocaleString()}
                                        </Text>
                                    </View>
                                ))
                            }
                        </View>
                    </ScrollView>
                    {renderFooterNav()}
                </View>
            )}

            {/* ----------------- SCREEN: INSIGHTS ----------------- */}
            {currentScreen === 'insights' && (
                <View style={styles.mainWrapper}>
                    {renderHeader()}
                    <Text style={styles.sectionHeader}>Rule-Based Financial Optimizer</Text>

                    <ScrollView style={styles.contentScroll}>

                        {/* Margin Insight */}
                        {(typeof finance.margin === 'number' && typeof targetMargin === 'string') &&
                            (finance.margin < parseFloat(targetMargin)) && (
                                <View style={styles.insightBox}>
                                    <Text style={styles.insightTitle}>⚠️ Margin Optimization Opportunity</Text>
                                    <Text style={styles.insightDesc}>
                                        Your current gross margin is <Text style={styles.bold}>{finance.margin.toFixed(1)}%</Text>, which is below your target of {targetMargin}%.
                                    </Text>
                                    <Text style={styles.insightAction}>
                                        Action: Review your highest expense categories to identify cost reduction opportunities.
                                    </Text>
                                    <TouchableOpacity
                                        style={[styles.actionBtn, styles.smallBtn, styles.insightActionBtn]}
                                        onPress={() => {
                                            setActiveReportTab('pnl');
                                            setCurrentScreen('reports');
                                        }}
                                    >
                                        <Text style={styles.actionBtnText}>Review P&L Statement</Text>
                                    </TouchableOpacity>
                                </View>
                            )}

                        {/* Profitability Insight */}
                        {finance.profit < 0 && (
                            <View style={styles.insightBox}>
                                <Text style={styles.insightTitle}>⚡ Profitability Concern</Text>
                                <Text style={styles.insightDesc}>
                                    Your business is currently operating at a loss of <Text style={styles.bold}>{currency}{Math.abs(finance.profit).toLocaleString()}</Text>.
                                </Text>
                                <Text style={styles.insightAction}>
                                    Action: Focus on increasing revenue streams or reducing operational expenses to achieve profitability.
                                </Text>
                                <TouchableOpacity
                                    style={[styles.actionBtn, styles.smallBtn, styles.insightActionBtn]}
                                    onPress={() => setCurrentScreen('transactions')}
                                >
                                    <Text style={styles.actionBtnText}>Review Transactions</Text>
                                </TouchableOpacity>
                            </View>
                        )}

                        {/* Positive Financial Position */}
                        {finance.profit >= 0 && (
                            <View style={styles.insightBox}>
                                <Text style={styles.insightTitle}>🟢 Positive Financial Position</Text>
                                <Text style={styles.insightDesc}>
                                    You are currently running with a net profit of <Text style={[styles.bold, styles.textGreen]}>{currency}{finance.profit.toLocaleString()}</Text>.
                                </Text>
                                <Text style={styles.insightAction}>
                                    Action: Consider allocating surplus funds to reserves or strategic investments.
                                </Text>
                                <TouchableOpacity
                                    style={[styles.actionBtn, styles.smallBtn, styles.insightActionBtn]}
                                    onPress={() => {
                                        setActiveReportTab('financial_planning');
                                        setCurrentScreen('reports');
                                    }}
                                >
                                    <Text style={styles.actionBtnText}>Plan Future Investments</Text>
                                </TouchableOpacity>
                            </View>
                        )}

                        {/* Additional Insights */}
                        <View style={styles.insightBox}>
                            <Text style={styles.insightTitle}>📊 Financial Health Check</Text>
                            <Text style={styles.insightDesc}>
                                Your business liquidity ratio is <Text style={styles.bold}>{(finance.assets / Math.max(finance.liabilities, 1)).toFixed(2)}:1</Text>
                            </Text>
                            <Text style={styles.insightAction}>
                                Action: Monitor debt levels and maintain adequate reserves.
                            </Text>
                            <View style={styles.insightActionsRow}>
                                <TouchableOpacity
                                    style={[styles.actionBtn, styles.smallBtn, styles.insightActionBtn]}
                                    onPress={() => {
                                        setActiveReportTab('financial_health');
                                        setCurrentScreen('reports');
                                    }}
                                >
                                    <Text style={styles.actionBtnText}>Health Assessment</Text>
                                </TouchableOpacity>
                                <TouchableOpacity
                                    style={[styles.actionBtn, styles.smallBtn, styles.insightActionBtn]}
                                    onPress={() => {
                                        setActiveReportTab('cash_flow_statement');
                                        setCurrentScreen('reports');
                                    }}
                                >
                                    <Text style={styles.actionBtnText}>Cash Flow Trends</Text>
                                </TouchableOpacity>
                            </View>
                        </View>

                    </ScrollView>
                    {renderFooterNav()}
                </View>
            )}

            {/* ----------------- MODAL: ADD TRANSACTION ----------------- */}
            <Modal visible={isTxModalOpen} animationType="slide" transparent>
                <View style={styles.modalBg}>
                    <View style={styles.modalContainer}>
                        <Text style={styles.modalTitle}>Log Enhanced Transaction</Text>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Description</Text>
                            <TextInput
                                style={styles.modalInput}
                                placeholder="Product design contract, supplier delivery"
                                placeholderTextColor="#64748b"
                                value={newTx.description}
                                onChangeText={(text) => setNewTx({ ...newTx, description: text })}
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Amount ({currency})</Text>
                            <TextInput
                                style={styles.modalInput}
                                keyboardType="numeric"
                                placeholder="5000"
                                placeholderTextColor="#64748b"
                                value={newTx.amount}
                                onChangeText={(text) => setNewTx({ ...newTx, amount: text })}
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Transaction Category</Text>
                            <View style={styles.toggleRow}>
                                {(['purchase', 'sale', 'expense', 'cost', 'other'] as const).map(category => (
                                    <TouchableOpacity
                                        key={category}
                                        style={[styles.toggleBtn, newTx.transactionCategory === category && styles.toggleBtnActive]}
                                        onPress={() => setNewTx({ ...newTx, transactionCategory: category })}
                                    >
                                        <Text style={[styles.toggleText, newTx.transactionCategory === category && styles.toggleTextActive]}>
                                            {category.charAt(0).toUpperCase() + category.slice(1)}
                                        </Text>
                                    </TouchableOpacity>
                                ))}
                            </View>
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Transaction Type</Text>
                            <View style={styles.toggleRow}>
                                <TouchableOpacity
                                    style={[styles.toggleBtn, newTx.type === 'expense' && styles.toggleBtnActive]}
                                    onPress={() => setNewTx({ ...newTx, type: 'expense' })}
                                >
                                    <Text style={[styles.toggleText, newTx.type === 'expense' && styles.toggleTextActive]}>Expense / Cost</Text>
                                </TouchableOpacity>
                                <TouchableOpacity
                                    style={[styles.toggleBtn, newTx.type === 'income' && styles.toggleBtnActive]}
                                    onPress={() => setNewTx({ ...newTx, type: 'income' })}
                                >
                                    <Text style={[styles.toggleText, newTx.type === 'income' && styles.toggleTextActive]}>Inflow / Revenue</Text>
                                </TouchableOpacity>
                            </View>
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Chart Category</Text>
                            <TextInput
                                style={styles.modalInput}
                                placeholder="Personnel, Software sales, Professional consulting"
                                placeholderTextColor="#64748b"
                                value={newTx.category}
                                onChangeText={(text) => setNewTx({ ...newTx, category: text })}
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Reference/Invoice #</Text>
                            <TextInput
                                style={styles.modalInput}
                                placeholder="INV-001, PO-2023-001"
                                placeholderTextColor="#64748b"
                                value={newTx.reference}
                                onChangeText={(text) => setNewTx({ ...newTx, reference: text })}
                            />
                        </View>

                        <View style={styles.formGroup}>
                            <Text style={styles.modalLabel}>Vendor/Customer</Text>
                            <TextInput
                                style={styles.modalInput}
                                placeholder="Supplier name, Customer name"
                                placeholderTextColor="#64748b"
                                value={newTx.vendorCustomer}
                                onChangeText={(text) => setNewTx({ ...newTx, vendorCustomer: text })}
                            />
                        </View>

                        <View style={styles.modalBtns}>
                            <TouchableOpacity style={[styles.primaryBtn, { flex: 1, backgroundColor: '#475569', marginRight: 10 }]} onPress={() => setIsTxModalOpen(false)}>
                                <Text style={styles.btnText}>Cancel</Text>
                            </TouchableOpacity>
                            <TouchableOpacity style={[styles.primaryBtn, { flex: 1, backgroundColor: '#10b981' }]} onPress={handleAddTransaction}>
                                <Text style={styles.btnText}>Commit Ledger</Text>
                            </TouchableOpacity>
                        </View>
                    </View>
                </View>
            </Modal>

