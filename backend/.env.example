PORT=3000
CORS_ORIGIN=*
BACKEND_URL=https://quad360-backend.onrender.com

# ── Paystack (Nigeria — cards, bank transfer, USSD, mobile money) ─────────────
# dashboard.paystack.com → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key_here

# ── Korapay (Nigeria — cards, bank transfer, USSD, mobile money) ──────────────
# merchant.korapay.com → Settings → API Keys
KORAPAY_SECRET_KEY=sk_live_your_korapay_secret_key_here

# ── Pngme (East & West Africa — SMS-based) ────────────────────────────────────
# admin.pngme.com → API & SDK Integration → API Tokens
PNGME_API_KEY=your_pngme_api_token_here
PNGME_WEBHOOK_SECRET=your_pngme_webhook_secret_here

# ── Mono (Nigeria, Ghana, Kenya — direct bank API) ────────────────────────────
# app.withmono.com → Settings → API Keys
MONO_SECRET_KEY=your_mono_secret_key_here

# ── Lean (Egypt, Saudi Arabia, UAE, Bahrain, Kuwait — open banking) ───────────
# dev.leantech.me → Settings → App Token
LEAN_APP_TOKEN=your_lean_app_token_here
LEAN_SANDBOX=true   # set to false in production

# ── Plaid (USA, UK, Canada, EU — open banking) ────────────────────────────────
# dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox   # sandbox | development | production
