PORT=3000

# Pngme API token (from admin.pngme.com → API & SDK Integration → API Tokens)
# Use your TEST token during development, switch to PRODUCTION before launch
PNGME_API_KEY=your_pngme_api_token_here

# Webhook secret — set this in Pngme dashboard when you create the webhook
PNGME_WEBHOOK_SECRET=your_pngme_webhook_secret_here

CORS_ORIGIN=*
