                                                <Text style={[styles.thCell, { flex: 1.5 }]}>Supplier</Text>
                                                <Text style={[styles.thCell, { flex: 1 }]}>Amount</Text>
                                                <Text style={[styles.thCell, { flex: 1 }]}>Due Date</Text>
                                                <Text style={[styles.thCell, { flex: 0.8 }]}>Days Left</Text>
