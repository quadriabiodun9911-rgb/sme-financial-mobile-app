# ============================================================================
# QUAD360 ENVIRONMENT VARIABLES
# ============================================================================
# Copy this to .env.local and fill in actual values
# See DEPLOYMENT_GUIDE.md for complete setup instructions

# ============================================================================
# REQUIRED: SUPABASE (Database & Auth)
# ============================================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# OPTIONAL: PAYMENT GATEWAYS
# ============================================================================
# Can also be configured in-app via Settings > Payment Gateways
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_KORAPAY_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL: MOBILE MONEY (Android SMS-based)
# ============================================================================
EXPO_PUBLIC_PNGME_SDK_TOKEN_TEST=your-pngme-test-sdk-token
EXPO_PUBLIC_PNGME_SDK_TOKEN_PROD=your-pngme-production-sdk-token
PNGME_API_KEY=your-pngme-production-token

# ============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================================================
EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================================
EXPO_PUBLIC_USE_NEW_COMPONENTS=true
EXPO_PUBLIC_ENABLE_FINANCING=true
EXPO_PUBLIC_ENABLE_TEAM=true
EXPO_PUBLIC_ENABLE_REPORTS=true

# ============================================================================
# OPTIONAL: DEBUG & DEVELOPMENT
# ============================================================================
EXPO_PUBLIC_DEBUG_LOGGING=false
EXPO_PUBLIC_MOCK_DATA=false
