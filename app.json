{
  "expo": {
    "name": "Quad360",
    "slug": "financebooks-smd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "owner": "quadriabiodun9911",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quad360.sme",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR codes for team invite codes.",
        "NSPhotoLibraryUsageDescription": "Used to attach receipts to transactions.",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "NSDocumentsFolderUsageDescription": "Used to import bank statements (CSV or Excel) for transaction analysis."
      }
    },
    "android": {
      "package": "com.quad360.sme",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "themeColor": "#0066cc",
      "backgroundColor": "#0f172a",
      "meta": {
        "theme-color": "#0066cc"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-updates"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "5577b2eb-04eb-4a01-bfad-6412b3cf1e29"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/5577b2eb-04eb-4a01-bfad-6412b3cf1e29"
    }
  }
}
